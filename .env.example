# 复制为 .env 后填写，用于本地运行：  cp .env.example .env
# （GitHub Actions 上不用这个文件，改在仓库 Settings → Secrets 里配置）

# 浏览器里复制的完整 Cookie 字符串（务必包含 SESSDATA、buvid3 等）
BILI_COOKIE="buvid3=...; SESSDATA=...; bili_jct=...; ..."

# 监控名单：本地运行就维护 subscriptions.txt（每行“名字 链接”）。
# （GitHub Actions 上还可以用仓库 Variable BILI_SUBS 多行配置，fork 后设一次即可，详见 README）
# 下面的 BILI_UIDS 可选，仅用于临时补充几个纯 UID，平时留空即可：
# BILI_UIDS="3706959876327428,11430504"

# ---- 推送渠道：下面挑一个（或多个）填上即可，都免费可选 ----

# Bark（iOS，最简单，推荐）：App 里复制你的推送地址
BARK_URL="https://api.day.app/你的key"

# 企业微信群机器人 Webhook（免费、无限量）
# WECOM_WEBHOOK="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx"

# ntfy（开源跨平台，免费）：自定义一个主题名
# NTFY_URL="https://ntfy.sh/我的B站动态-随便起个独特名字"

# Server酱（推到微信，有免费额度；SCT 开头=Turbo，sctp 开头=Server酱³）
# SERVERCHAN_SENDKEY="SCTxxxxxxxxxxxxxxxxx"

# Telegram Bot（需能访问 Telegram）
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# TELEGRAM_CHAT_ID="123456789"

# 可选：单次运行最多推送几条（防刷屏），默认 10
# MAX_PUSH_PER_RUN=10

# 抓取模式：
#   space（默认）= 逐个 UP 拉空间动态，无需关注；UP 多时请求量大，不宜高频。
#   all          = feed/all 合并单请求，一次拿到「所有关注 UP」的最新动态，按名单过滤。
#                  请求量极低（每轮通常 1 个请求），适合监控较多 UP + 1 分钟级低延迟。
#                  前提：用这个监控账号“关注”名单里的所有 UP。
# BILI_FEED_MODE=all
# FEED_ALL_MAX_PAGES=3   # all 模式自适应翻页上限，关注的人很多时可调大
